rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users: owner-only access (read/write own document)
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Default: deny all reads and writes for other collections
    // Additional per-collection rules added in Story 1.4b
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
