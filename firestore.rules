rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === TRIPS ===
    // Read: public (catalog is a marketing asset, SSG/ISR for SEO)
    // Write: admin/superadmin only
    match /trips/{tripId} {
      allow read: if true;
      allow write: if request.auth != null
                   && ('admin' in request.auth.token.roles
                       || 'superadmin' in request.auth.token.roles);

      // Departures subcollection (event-based departures per trip)
      // Read: public (same as trips — needed for catalog availability display)
      // Write: admin/superadmin only (sync writes via Admin SDK bypass rules)
      match /departures/{departureId} {
        allow read: if true;
        allow write: if request.auth != null
                     && ('admin' in request.auth.token.roles
                         || 'superadmin' in request.auth.token.roles);
      }
    }

    // === AGENTS (with subcollections) ===
    // Agent isolation: only own agentId. Admin/Director/SuperAdmin can read
    match /agents/{agentId}/{document=**} {
      allow read: if request.auth != null
                  && (request.auth.token.agentId == agentId
                      || 'admin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if request.auth != null
                   && request.auth.token.agentId == agentId;
    }

    // === USERS ===
    // Owner read/write. Admin/SuperAdmin read-only.
    // bankData requires agente role. fiscalData RFC validated.
    match /users/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || 'admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);

      allow create: if request.auth != null
                    && request.auth.uid == uid;

      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && bankDataAllowed()
                    && fiscalRfcValid();

      // Delete: Admin SDK only
      allow delete: if false;

      // bankData changes require agente role
      function bankDataAllowed() {
        return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['bankData'])
               || 'agente' in request.auth.token.roles;
      }

      // If fiscalData is written, RFC must match SAT format
      function fiscalRfcValid() {
        return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['fiscalData'])
               || (request.resource.data.fiscalData is map
                   && 'rfc' in request.resource.data.fiscalData
                   && request.resource.data.fiscalData.rfc.matches('^[A-ZÑ&]{3,4}[0-9]{6}[A-Z0-9]{3}$'));
      }
    }

    // === CONFIG (permissions, settings) ===
    // Read: authenticated. Write: NEVER from client
    match /config/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // === ODOO CACHE ===
    // Read: authenticated users. Write: NEVER from client (Admin SDK only)
    match /odooCache/{model}/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // === AUDIT LOG ===
    // Read: admin/superadmin only. Write: NEVER from client (Admin SDK only)
    match /auditLog/{logId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === DEFAULT DENY ===
    // Any unspecified collection: denied
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
