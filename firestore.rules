rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === TRIPS ===
    // Read: public (catalog is a marketing asset, SSG/ISR for SEO)
    // Write: admin/superadmin only
    match /trips/{tripId} {
      allow read: if true;
      allow write: if request.auth != null
                   && ('admin' in request.auth.token.roles
                       || 'superadmin' in request.auth.token.roles);

      // Departures subcollection (event-based departures per trip)
      // Read: public (same as trips — needed for catalog availability display)
      // Write: admin/superadmin only (sync writes via Admin SDK bypass rules)
      match /departures/{departureId} {
        allow read: if true;
        allow write: if request.auth != null
                     && ('admin' in request.auth.token.roles
                         || 'superadmin' in request.auth.token.roles);
      }
    }

    // === AGENTS (with subcollections) ===
    // Agent isolation: only own agentId. Admin/Director/SuperAdmin can read
    match /agents/{agentId}/{document=**} {
      allow read: if request.auth != null
                  && (request.auth.token.agentId == agentId
                      || 'admin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if request.auth != null
                   && request.auth.token.agentId == agentId;
    }

    // === COMMISSIONS (agent subcollection) ===
    // Write: NEVER from client (Admin SDK only via verify hook)
    // Overrides wildcard rule above for this specific subcollection
    match /agents/{agentId}/commissions/{commissionId} {
      allow read: if request.auth != null
                  && (request.auth.token.agentId == agentId
                      || 'admin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === USERS ===
    // Owner read/write. Admin/SuperAdmin read-only.
    // bankData requires agente role. fiscalData RFC validated.
    match /users/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || 'admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);

      allow create: if request.auth != null
                    && request.auth.uid == uid;

      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && bankDataAllowed()
                    && fiscalRfcValid();

      // Delete: Admin SDK only
      allow delete: if false;

      // bankData changes require agente role
      function bankDataAllowed() {
        return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['bankData'])
               || 'agente' in request.auth.token.roles;
      }

      // If fiscalData is written, RFC must match SAT format
      function fiscalRfcValid() {
        return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['fiscalData'])
               || (request.resource.data.fiscalData is map
                   && 'rfc' in request.resource.data.fiscalData
                   && request.resource.data.fiscalData.rfc.matches('^[A-ZÑ&]{3,4}[0-9]{6}[A-Z0-9]{3}$'));
      }
    }

    // === CONFIG (permissions, settings) ===
    // Read: authenticated. Write: NEVER from client
    match /config/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // === ODOO CACHE ===
    // Read: authenticated users. Write: NEVER from client (Admin SDK only)
    match /odooCache/{model}/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // === ORDERS ===
    // Read: owner OR admin/director/superadmin
    // Write/Delete: NEVER from client (Admin SDK only via Route Handler)
    match /orders/{orderId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.userId
                      || 'admin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
      allow delete: if false;
    }

    // === AGENT CONTACTS ===
    // Agent-created contacts (platform-side). Read: owner agent or admin+.
    // Write: NEVER from client (Admin SDK only via API routes)
    match /agentContacts/{contactId} {
      allow read: if request.auth != null
                  && (request.auth.token.agentId == resource.data.agentId
                      || 'admin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === AUDIT LOG ===
    // Read: admin/superadmin only. Write: NEVER from client (Admin SDK only)
    match /auditLog/{logId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === PAYMENT RECONCILIATION LOG (Story 9.1 PARTE A) ===
    // Read: admin/superadmin only. Write: NEVER from client (Admin SDK only via API)
    match /paymentReconciliationLog/{logId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === PAYMENT DEDUP LOG (Story 9.1 PARTE B) ===
    // Read: admin/superadmin only. Write: NEVER from client (Admin SDK only via API)
    match /paymentDedupLog/{logId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === PAYMENT DEDUP DISMISSALS / FLAGS (Story 9.1 UX) ===
    // Soft-state Firestore-only sobre clusters Odoo. Read/write via Admin SDK desde API.
    match /paymentDedupDismissals/{clusterId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }
    match /paymentDedupFlags/{clusterId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === PAYMENTS (Epic 3 + Epic 9 mirror) ===
    // Read: agente (sus pagos), admin/director/superadmin.
    // Write: NEVER from client (Admin SDK only via API routes + sync jobs).
    // Los campos `odoo*` y `lww.*` son mirror — escritos SOLO por el pull (Story 9.3).
    match /payments/{paymentId} {
      allow read: if request.auth != null
                  && (request.auth.token.agentId == resource.data.agentId
                      || 'admin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === SYNC CURSORS (Story 9.3) ===
    // Cursor de polling Odoo→Firestore. Solo Admin SDK escribe. Admin/director lee.
    match /syncCursors/{cursorId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === PAYMENT ALERTS (Story 9.3 + Story 9.6) ===
    // Alertas detectadas por sync jobs (odoo_canceled, attachment_failed, etc).
    // Write: NEVER from client. Read: admin+ y agente dueño del pago referenciado
    // (el doc lleva paymentId; admin SDK decide rule por separado al consultar).
    match /paymentAlerts/{alertId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === PAYMENT CONFLICTS (Story 9.3 + Story 9.6) ===
    // Cola de conflictos LWW Firestore↔Odoo. Solo Admin SDK escribe.
    match /paymentConflicts/{conflictId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === FOLDER DEDUP LOG (Story 9.5) ===
    // Bitácora de la dedup de folders Odoo Documents (33 clusters).
    // Solo Admin SDK escribe (scripts/execute-9-5-folder-dedup.mjs).
    match /folderDedupLog/{logId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === SYNC LOG (Story 9.2 + Story 9.3) ===
    // Bitácora interna de operaciones del sync. Solo Admin SDK escribe.
    match /syncLog/{logId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles);
      allow write: if false;
    }

    // === CONTRACT TEMPLATES (Story 10.1) ===
    // Catálogo de plantillas por destino. Solo admin/superadmin lee desde cliente
    // (UI selector). Write SIEMPRE via Admin SDK (lazy-seed + futuro CRUD admin).
    match /contractTemplates/{templateId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles);
      allow write: if false;
    }

    // === CONTRACTS (Story 10.1 — sesión 43) ===
    // Read:
    //   - admin/superadmin/director siempre
    //   - cliente dueño cuando sharedWithClient=true
    //   - agente asignado cuando sharedWithAgent=true
    // Write: Admin SDK únicamente (generate/share/accept endpoints).
    match /contracts/{contractId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles
                      || (resource.data.sharedWithClient == true
                          && resource.data.clientUserId == request.auth.uid)
                      || (resource.data.sharedWithAgent == true
                          && resource.data.agentId == request.auth.token.agentId));
      allow write: if false;
    }

    // === QUOTATIONS (Story 10.1) ===
    // Leads y cotizaciones. Read: admin/superadmin/director.
    // Create público SOLO desde `/cotizar` con shape estricto (source='cotizar-public',
    // status='lead', pdfUrl=null, pdfVersion=0). Update/delete: Admin SDK.
    match /quotations/{quotationId} {
      allow read: if request.auth != null
                  && ('admin' in request.auth.token.roles
                      || 'superadmin' in request.auth.token.roles
                      || 'director' in request.auth.token.roles);
      allow create: if request.resource.data.source == 'cotizar-public'
                    && request.resource.data.status == 'lead'
                    && request.resource.data.pdfUrl == null
                    && request.resource.data.pdfVersion == 0
                    && request.resource.data.whatsappSent == true
                    && request.resource.data.createdBy == null;
      allow update, delete: if false;
    }

    // === DEFAULT DENY ===
    // Any unspecified collection: denied
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
