# === Firebase Client SDK ===
# Source: Firebase Console > Project Settings > General > Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=arounda-planet.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=arounda-planet
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=arounda-planet.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Firebase FCM (Push Notifications) ===
# Source: .keys/pushkeys.txt (VAPID public key)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# === Odoo (Server-side only) ===
# Source: Odoo Admin Panel > Settings > API Keys
ODOO_URL=https://aroundaplanet.odoo.com
ODOO_DB=aroundaplanet
ODOO_API_KEY=

# === Odoo Journals (Story 9.2 push Firestore→Odoo) ===
# Source: Odoo > Accounting > Configuration > Journals (Bank/Cash) — copiar ID numérico
# Resolver con: pnpm tsx scripts/verify-9-2-odoo.mjs --list-journals (o pedir a Paloma)
ODOO_JOURNAL_BANK_DEFAULT_ID=
ODOO_JOURNAL_CASH_ID=
# Feature flag: reconciliación automática post-push. Default false; activar
# solo cuando Paloma confirme que quiere conciliación automática a invoices.
ODOO_AUTO_RECONCILE=false

# === Analytics (optional — leave empty to disable) ===
# Source: Facebook Business Manager > Events Manager > Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=
# Source: Google Tag Manager > Container ID (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=
